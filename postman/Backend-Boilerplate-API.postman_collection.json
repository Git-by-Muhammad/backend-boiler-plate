{
  "info": {
    "name": "Backend Boilerplate API",
    "description": "Health, upload (single/multiple), and Items CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "itemId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Single",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/upload/single"
          }
        },
        {
          "name": "Upload Multiple",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "files", "type": "file", "src": "" },
                { "key": "files", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/upload/multiple"
          }
        }
      ]
    },
    {
      "name": "Items",
      "item": [
        {
          "name": "Create Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) pm.collectionVariables.set('itemId', res._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Item\",\n  \"description\": \"Created from Postman\",\n  \"imageUrl\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/items"
          }
        },
        {
          "name": "List Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/items?page=1&limit=10&sort=-createdAt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "items"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "-createdAt" }
              ]
            }
          }
        },
        {
          "name": "Get Item",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/items/{{itemId}}"
          }
        },
        {
          "name": "Update Item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Item\",\n  \"description\": \"Updated from Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/items/{{itemId}}"
          }
        },
        {
          "name": "Delete Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/items/{{itemId}}"
          }
        }
      ]
    }
  ]
}
